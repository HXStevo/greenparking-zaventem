{% extends "_layout.njk" %}

{% block content %}
    <section class="section">
        <div class="container">
            <div class="two-col">
                <div class="two-col-content">
                    <h1 style="font-size: 38px; font-weight: 800; color: var(--color-primary); line-height: 1.2;">{{ page.hero.heading | safe }}</h1>
                    {% for p in page.hero.paragraphs %}
                    <p {% if loop.first %}style="margin-top: 20px;"{% endif %}>{{ p | safe }}</p>
                    {% endfor %}
                </div>
                <div>
                    <img src="{{ page.hero.image }}" alt="{{ page.hero.image_alt }}" style="border-radius: 12px;">
                </div>
            </div>
        </div>
    </section>

    <!-- Stats -->
    <section class="section section-light">
        <div class="container">
            <div class="stats-row">
                {% for stat in page.stats %}
                <div class="stat-item">
                    <h3>{{ stat.value }}</h3>
                    <p>{{ stat.label }}</p>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Benefits -->
    <section class="section">
        <div class="container">
            <h2 style="margin-bottom: 30px;">{{ page.benefits.heading }}</h2>
            <div class="two-col">
                <div class="benefits-list">
                    {% for item in page.benefits.items_left %}
                    <div class="benefit-item"><span class="benefit-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg></span>{{ item }}</div>
                    {% endfor %}
                </div>
                <div class="benefits-list">
                    {% for item in page.benefits.items_right %}
                    <div class="benefit-item"><span class="benefit-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg></span>{{ item }}</div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>

    <!-- Location Info -->
    <section class="section section-light">
        <div class="container">
            <div class="two-col">
                <div>
                    <img src="{{ page.location.image }}" alt="Parkeerterrein" style="border-radius: 12px;">
                </div>
                <div class="two-col-content">
                    <h2>{{ page.location.heading | safe }}</h2>
                    {% for p in page.location.paragraphs %}
                    <p>{{ p | safe }}</p>
                    {% endfor %}
                    <a href="reserveren.html" class="btn-cta" style="margin-top: 15px;">Reserveer mijn plek &rarr;</a>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
