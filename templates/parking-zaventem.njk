{% extends "_layout.njk" %}

{% block content %}
    <section class="section">
        <div class="container">
            <div class="two-col">
                <div class="two-col-content">
                    <h1 style="font-size: 38px; font-weight: 800; color: var(--color-primary); line-height: 1.2;">{{ page.hero.heading | safe }}</h1>
                    <p style="margin-top: 20px;">{{ page.hero.text }}</p>
                </div>
                <div>
                    <img src="{{ page.hero.image }}" alt="{{ page.hero.image_alt }}" style="border-radius: 12px;">
                </div>
            </div>
        </div>
    </section>

    <!-- Booking Widget -->
    <section class="section section-light">
        <div class="container">
            <h2 style="margin-bottom: 25px;">{{ page.booking.heading }}</h2>
            {% include "_partials/booking-form.njk" %}
        </div>
    </section>

    <!-- Shuttle Parking -->
    <section class="section">
        <div class="container">
            <div class="two-col">
                <div>
                    <img src="{{ page.shuttle.image }}" alt="{{ page.shuttle.image_alt }}" style="border-radius: 12px;">
                </div>
                <div class="two-col-content">
                    <h2>{{ page.shuttle.heading | safe }}</h2>
                    {% for p in page.shuttle.paragraphs %}
                    <p>{{ p }}</p>
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>

    <!-- Zo werkt parkeren -->
    <section class="section section-light">
        <div class="container">
            <div class="section-header">
                <h2>{{ page.how_it_works.heading }}<br><em>{{ page.how_it_works.heading_emphasis }}</em></h2>
            </div>
            <div class="card-grid">
                {% for card in page.how_it_works.cards %}
                <div class="card">
                    <img src="{{ card.image }}" alt="{{ card.alt }}">
                    <p>{{ card.text }}</p>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Benefits -->
    <section class="section">
        <div class="container">
            <div class="two-col">
                <div class="two-col-content">
                    <h2>{{ page.benefits.heading | safe }}</h2>
                    <div class="benefits-list" style="margin-top: 25px;">
                        {% for item in page.benefits.items %}
                        <div class="benefit-item"><span class="benefit-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg></span>{{ item }}</div>
                        {% endfor %}
                    </div>
                </div>
                <div>
                    <img src="{{ page.benefits.image }}" alt="Reiziger" style="border-radius: 12px;">
                </div>
            </div>
        </div>
    </section>

    <!-- Location -->
    <section class="section section-light">
        <div class="container">
            <div class="two-col">
                <div>
                    <img src="{{ page.location.image }}" alt="Parkeerlocatie" style="border-radius: 12px;">
                </div>
                <div class="two-col-content">
                    <h2>{{ page.location.heading | safe }}</h2>
                    {% for p in page.location.paragraphs %}
                    <p>{{ p }}</p>
                    {% endfor %}
                    <a href="reserveren.html" class="btn-cta" style="margin-top: 15px;">Reserveer mijn plek &rarr;</a>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
