{% extends "_layout.njk" %}

{% block content %}
    <section class="section">
        <div class="container">
            <div class="section-header">
                <h1 style="font-size: 38px; font-weight: 800; color: var(--color-primary);">{{ page.heading }}</h1>
                <p style="color: var(--color-text-secondary); margin-top: 10px; max-width: 600px; margin-left: auto; margin-right: auto;">{{ page.intro }}</p>
            </div>

            <div class="contact-grid">
                {% for card in page.contact_cards %}
                <div class="contact-card">
                    <div class="contact-card-icon">{{ card.icon | safe }}</div>
                    <h3>{{ card.title }}</h3>
                    <p>{{ card.text }}</p>
                    <a href="{{ card.link_url }}" class="card-link">{{ card.link_text | safe }}</a>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Service Benefits -->
    <section class="section section-light">
        <div class="container">
            <h2 style="margin-bottom: 30px;">{{ page.service.heading }}</h2>
            <div class="two-col">
                <div class="benefits-list">
                    {% for item in page.service.items_left %}
                    <div class="benefit-item"><span class="benefit-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg></span>{{ item }}</div>
                    {% endfor %}
                </div>
                <div class="benefits-list">
                    {% for item in page.service.items_right %}
                    <div class="benefit-item"><span class="benefit-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg></span>{{ item }}</div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>

    <!-- Location -->
    <section class="section">
        <div class="container">
            <div class="two-col">
                <div>
                    <img src="{{ page.location.image }}" alt="Parkeerlocatie" style="border-radius: 12px;">
                </div>
                <div class="two-col-content">
                    <h2>{{ page.location.heading }}</h2>
                    {% for p in page.location.paragraphs %}
                    <p>{{ p }}</p>
                    {% endfor %}
                    <a href="reserveren.html" class="btn-cta" style="margin-top: 15px;">Reserveer mijn plek &rarr;</a>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
