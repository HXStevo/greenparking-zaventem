{% extends "_layout.njk" %}

{% block content %}
    <!-- Hero -->
    <section class="section">
        <div class="container">
            <div class="two-col">
                <div class="two-col-content">
                    <h1 style="font-size: 38px; font-weight: 800; color: var(--color-primary); line-height: 1.2;">{{ page.hero.heading | safe }}</h1>
                    {% for p in page.hero.paragraphs %}
                    <p {% if loop.first %}style="margin-top: 20px;"{% endif %}>{{ p }}</p>
                    {% endfor %}
                </div>
                <div>
                    <img src="{{ page.hero.image }}" alt="{{ page.hero.image_alt }}" style="border-radius: 12px;">
                </div>
            </div>
        </div>
    </section>

    <!-- Three Benefits -->
    <section class="section section-light">
        <div class="container">
            <div class="section-header">
                <h2>{{ page.benefits.heading | safe }}</h2>
            </div>
            <div class="card-grid card-grid-3">
                {% for card in page.benefits.cards %}
                <div class="feature-card">
                    <div class="feature-card-icon">
                        {% if card.icon == "terminal" %}
                        <svg viewBox="0 0 24 24" fill="none" stroke="#88BC24" stroke-width="2"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
                        {% elif card.icon == "clock" %}
                        <svg viewBox="0 0 24 24" fill="none" stroke="#88BC24" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        {% elif card.icon == "phone" %}
                        <svg viewBox="0 0 24 24" fill="none" stroke="#88BC24" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                        {% endif %}
                    </div>
                    <h3>{{ card.title }}</h3>
                    <p>{{ card.text }}</p>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Booking Widget -->
    <section class="section">
        <div class="container">
            <h2 style="margin-bottom: 25px;">{{ page.booking.heading }}</h2>
            {% include "_partials/booking-form.njk" %}
        </div>
    </section>

    <!-- Zaventem lang parkeren -->
    <section class="section section-light">
        <div class="container">
            <div class="two-col">
                <div>
                    <img src="{{ page.long_parking.image }}" alt="{{ page.long_parking.image_alt }}" style="border-radius: 12px;">
                </div>
                <div class="two-col-content">
                    <h2>{{ page.long_parking.heading | safe }}</h2>
                    {% for p in page.long_parking.paragraphs %}
                    <p>{{ p }}</p>
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>

    <!-- Lang parkeren met GreenParking -->
    <section class="section">
        <div class="container">
            <div class="two-col">
                <div class="two-col-content">
                    <h2>{{ page.greenparking_long.heading | safe }}</h2>
                    {% for p in page.greenparking_long.paragraphs %}
                    <p>{{ p }}</p>
                    {% endfor %}
                </div>
                <div>
                    <img src="{{ page.greenparking_long.image }}" alt="{{ page.greenparking_long.image_alt }}" style="border-radius: 12px;">
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section section-light">
        <div class="container" style="text-align: center; max-width: 700px;">
            <h2>{{ page.cta.heading | safe }}</h2>
            <p style="margin-top: 15px;">{{ page.cta.text }}</p>
            <p style="margin-top: 10px;">Bel ons op <strong>{{ page.cta.phone }}</strong></p>
            <a href="{{ page.cta.button_url }}" class="btn-cta" style="margin-top: 20px;">{{ page.cta.button_text }} &rarr;</a>
        </div>
    </section>
{% endblock %}
