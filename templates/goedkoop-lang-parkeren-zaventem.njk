{% extends "_layout.njk" %}

{% block content %}
    <!-- Hero Section -->
    <section class="section">
        <div class="container">
            <div class="two-col">
                <div class="two-col-content">
                    <h1 style="font-size: 38px; font-weight: 800; color: var(--color-primary); line-height: 1.2;">{{ page.hero.heading | safe }}</h1>
                    {% for p in page.hero.paragraphs %}
                    <p {% if loop.first %}style="margin-top: 20px;"{% endif %}>{{ p }}</p>
                    {% endfor %}
                </div>
                <div>
                    <img src="{{ page.hero.image }}" alt="{{ page.hero.image_alt }}" style="border-radius: 12px;">
                </div>
            </div>
        </div>
    </section>

    <!-- Benefits: Three Column Icon Cards -->
    <section class="section section-light">
        <div class="container">
            <div class="section-header">
                <h2>{{ page.benefits.heading | safe }}</h2>
            </div>
            <div class="card-grid card-grid-3">
                {% for card in page.benefits.cards %}
                <div class="feature-card">
                    <div class="feature-card-icon">
                        {% if card.icon == "location" %}
                        <svg viewBox="0 0 24 24" fill="none" stroke="#88BC24" stroke-width="2"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
                        {% elif card.icon == "clock" %}
                        <svg viewBox="0 0 24 24" fill="none" stroke="#88BC24" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        {% elif card.icon == "phone" %}
                        <svg viewBox="0 0 24 24" fill="none" stroke="#88BC24" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                        {% endif %}
                    </div>
                    <h3>{{ card.title }}</h3>
                    <p>{{ card.text }}</p>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Booking Widget -->
    <section class="section">
        <div class="container">
            <h2 style="margin-bottom: 25px;">{{ page.booking.heading }}</h2>
            {% include "_partials/booking-form.njk" %}
        </div>
    </section>

    <!-- Parkeer op onze parkings -->
    <section class="section section-light">
        <div class="container">
            <div class="two-col">
                <div>
                    <img src="{{ page.parkings.image }}" alt="{{ page.parkings.image_alt }}" style="border-radius: 12px;">
                </div>
                <div class="two-col-content">
                    <h2>{{ page.parkings.heading | safe }}</h2>
                    {% for p in page.parkings.paragraphs %}
                    <p>{{ p }}</p>
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>

    <!-- Het gemak van GreenParking -->
    <section class="section">
        <div class="container">
            <div class="two-col">
                <div class="two-col-content">
                    <h2>{{ page.gemak.heading | safe }}</h2>
                    {% for p in page.gemak.paragraphs %}
                    <p>{{ p }}</p>
                    {% endfor %}
                </div>
                <div>
                    <img src="{{ page.gemak.image }}" alt="{{ page.gemak.image_alt }}" style="border-radius: 12px;">
                </div>
            </div>
        </div>
    </section>

    <!-- Security Benefits -->
    <section class="image-section" style="background-image: url('{{ page.security.image }}');">
        <div class="container">
            <h2 style="color: var(--color-white); margin-bottom: 30px;">{{ page.security.heading | safe }}</h2>
            <div class="benefits-list benefits-list-white">
                {% for item in page.security.items %}
                <div class="benefit-item"><span class="benefit-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg></span>{{ item }}</div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="section">
        <div class="container">
            <div class="two-col">
                <div class="two-col-content">
                    <h2>{{ page.cta.heading | safe }}</h2>
                    <p>{{ page.cta.text }}</p>
                    <a href="reserveren.html" class="btn-cta" style="margin-top: 15px;">Reserveer mijn plek &rarr;</a>
                </div>
                <div>
                    <img src="{{ page.cta.image }}" alt="{{ page.cta.image_alt }}" style="border-radius: 12px;">
                </div>
            </div>
        </div>
    </section>
{% endblock %}
