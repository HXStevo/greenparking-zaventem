{% extends "_layout.njk" %}

{% block content %}
    <!-- Main Content -->
    <section class="section">
        <div class="container">
            <div class="two-col">
                <div class="two-col-content">
                    <h1 style="font-size: 38px; font-weight: 800; color: var(--color-primary); line-height: 1.2;">{{ page.hero.heading | safe }}</h1>
                    {% for p in page.hero.paragraphs %}
                    <p {% if loop.first %}style="margin-top: 20px;"{% endif %}>{{ p }}</p>
                    {% endfor %}
                </div>
                <div>
                    <img src="{{ page.hero.image }}" alt="{{ page.hero.image_alt }}" style="border-radius: 12px;">
                </div>
            </div>
        </div>
    </section>

    <!-- Three Feature Cards -->
    <section class="section section-light">
        <div class="container">
            <div class="card-grid card-grid-3">
                {% for card in page.feature_cards %}
                <div class="feature-card">
                    <div class="feature-card-icon">
                        {% if card.icon == "location" %}
                        <svg viewBox="0 0 24 24" fill="none" stroke="#88BC24" stroke-width="2"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
                        {% elif card.icon == "bus" %}
                        <svg viewBox="0 0 24 24" fill="none" stroke="#88BC24" stroke-width="2"><rect x="1" y="6" width="22" height="12" rx="2"/><circle cx="6" cy="18" r="2"/><circle cx="18" cy="18" r="2"/><path d="M5 6V4h14v2"/></svg>
                        {% elif card.icon == "clock" %}
                        <svg viewBox="0 0 24 24" fill="none" stroke="#88BC24" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        {% endif %}
                    </div>
                    <h3>{{ card.title }}</h3>
                    <p>{{ card.text }}</p>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- How shuttle works -->
    <section class="section">
        <div class="container">
            <div class="two-col">
                <div>
                    <img src="{{ page.how_shuttle_works.image }}" alt="{{ page.how_shuttle_works.image_alt }}" style="border-radius: 12px;">
                </div>
                <div class="two-col-content">
                    <h2>{{ page.how_shuttle_works.heading | safe }}</h2>
                    {% for p in page.how_shuttle_works.paragraphs %}
                    <p>{{ p }}</p>
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>

    <!-- Benefits with background -->
    <section class="image-section" style="background-image: url('{{ page.benefits_banner.image }}');">
        <div class="container">
            <h2 style="color: var(--color-white); margin-bottom: 30px;">{{ page.benefits_banner.heading }}</h2>
            <div class="benefits-list benefits-list-white">
                {% for item in page.benefits_banner.items %}
                <div class="benefit-item"><span class="benefit-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg></span>{{ item }}</div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section">
        <div class="container">
            <div class="two-col">
                <div class="two-col-content">
                    <h2>{{ page.cta.heading | safe }}</h2>
                    {% for p in page.cta.paragraphs %}
                    <p>{{ p | safe }}</p>
                    {% endfor %}
                    <a href="reserveren.html" class="btn-cta" style="margin-top: 15px;">Reserveer mijn plek &rarr;</a>
                </div>
                <div>
                    <img src="{{ page.cta.image }}" alt="Parkeerterrein" style="border-radius: 12px;">
                </div>
            </div>
        </div>
    </section>
{% endblock %}
