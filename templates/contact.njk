{% extends "_layout.njk" %}

{% block content %}
    <section class="section">
        <div class="container">
            <h1 style="font-size: 38px; font-weight: 800; color: var(--color-primary); margin-bottom: 15px;">{{ page.heading }}</h1>
            <p style="color: var(--color-text-secondary); margin-bottom: 40px;">{{ page.intro }}</p>

            <div class="contact-grid">
                {% for card in page.contact_cards %}
                <div class="contact-card">
                    <div class="contact-card-icon">{{ card.icon | safe }}</div>
                    <h3>{{ card.title }}</h3>
                    <p>{{ card.text }}</p>
                    <a href="{{ card.link_url }}" class="card-link">{{ card.link_text | safe }}</a>
                </div>
                {% endfor %}
            </div>

            <div class="divider"></div>

            <h2 style="margin-bottom: 30px; text-align: center;">{{ page.form.heading }}</h2>
            <form class="contact-form">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div class="form-group">
                        <label>Naam *</label>
                        <input type="text" name="name" required placeholder="Je naam">
                    </div>
                    <div class="form-group">
                        <label>E-mail *</label>
                        <input type="email" name="email" required placeholder="Je e-mailadres">
                    </div>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div class="form-group">
                        <label>Telefoon</label>
                        <input type="tel" name="phone" placeholder="Je telefoonnummer">
                    </div>
                    <div class="form-group">
                        <label>Onderwerp</label>
                        <select name="subject">
                            <option value="">Selecteer een onderwerp</option>
                            {% for subject in page.form.subjects %}
                            <option>{{ subject }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Bericht *</label>
                    <textarea name="message" required placeholder="Typ je bericht hier..."></textarea>
                </div>
                <button type="submit" class="btn-cta">Verstuur bericht &rarr;</button>
            </form>
        </div>
    </section>
{% endblock %}
