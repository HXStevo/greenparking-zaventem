<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page.title }}</title>
    <meta name="description" content="{{ page.meta_description }}">
    {% if page.og_title %}
    <meta property="og:title" content="{{ page.og_title }}">
    <meta property="og:description" content="{{ page.og_description }}">
    <meta property="og:type" content="website">
    {% endif %}
    <link rel="stylesheet" href="css/style.css">
    <link rel="icon" type="image/svg+xml" href="{{ globals.logo }}">

    <!-- Prefetch QuickParking booking engine for faster availability -->
    <link rel="dns-prefetch" href="https://book.quickparking.com">
    <link rel="dns-prefetch" href="https://content-api.dock-yard.io">
    <link rel="dns-prefetch" href="https://d17s4kc6349e5h.cloudfront.net">
    <link rel="dns-prefetch" href="https://holidayextras.imgix.net">
    <link rel="preconnect" href="https://book.quickparking.com" crossorigin>
    <link rel="preconnect" href="https://content-api.dock-yard.io" crossorigin>
    <link rel="preconnect" href="https://d17s4kc6349e5h.cloudfront.net" crossorigin>

    <!-- Orion Tracking by Spiny -->
    <script>
        window.orion = window.orion || {queue: []};
        ['init', 'registerElement', 'setConfig', 'setContext', 'newPageView', 'on'].forEach(function(fn) {
            window.orion[fn] = function() {
                window.orion.queue.push({fn: fn, args: arguments});
            }
        });
    </script>
    <script async src="https://dbq5t2jl0vcpj.cloudfront.net/hx-tracker/tracker-v5-latest.min.js"></script>
</head>
<body>
    {% include "_partials/header.njk" %}

    {% include "_partials/usp-bar.njk" %}

    {% block content %}{% endblock %}

    {% include "_partials/bottom-usp.njk" %}
    {% include "_partials/footer.njk" %}
    <script>
        window.AGENT_CONFIG = {
            defaultAgent: "{{ globals.agents.default }}",
            searchAgent: "{{ globals.agents.search }}"
        };
    </script>
    <script src="js/agents.js"></script>
    <script src="js/main.js"></script>
</body>
</html>
